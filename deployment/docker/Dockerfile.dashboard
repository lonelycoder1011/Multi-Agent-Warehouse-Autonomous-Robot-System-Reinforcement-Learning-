FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn[standard] websockets aiofiles numpy gymnasium pyyaml

COPY dashboard/ ./dashboard/
COPY src/ ./src/

EXPOSE 8080
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s CMD curl -f http://localhost:8080/health || exit 1
CMD ["uvicorn", "dashboard.app:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "1"]
